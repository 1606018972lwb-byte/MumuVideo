# -----------------------------------------------------------------------------
# 数据库 (PostgreSQL)
# 请从数据库提供商获取 URL（Neon、Supabase 等）
# -----------------------------------------------------------------------------
DATABASE_URL='postgresql://user:password@host:port/database?sslmode=require'
# 可选：覆盖 SSL 模式（disable | require）。未设置时根据主机名自动检测。
# 适用于 Docker/内部部署等不需要 SSL 的场景。
# DATABASE_SSL_MODE=disable

# -----------------------------------------------------------------------------
# 应用
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL='http://localhost:3000'
# 默认支付提供商（creem | stripe）
NEXT_PUBLIC_BILLING_PROVIDER="creem"

# -----------------------------------------------------------------------------
# 认证 (Better Auth)
# 生成密钥方式：openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET='your_better_auth_secret_here'

# Google OAuth（获取凭据：https://console.cloud.google.com/）
GOOGLE_CLIENT_ID='your_google_client_id'
GOOGLE_CLIENT_SECRET='your_google_client_secret'

# -----------------------------------------------------------------------------
# 邮件 (RESEND)
# 获取 API 密钥：https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY='re_your_resend_api_key'
RESEND_FROM='noreply@yourdomain.com'

# -----------------------------------------------------------------------------
# 订阅 (Stripe) - 使用 Creem 时可选
# -----------------------------------------------------------------------------
STRIPE_API_KEY="sk_test_your_stripe_api_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_STD_PRODUCT_ID="prod_xxx"
NEXT_PUBLIC_STRIPE_STD_MONTHLY_PRICE_ID="price_xxx"

NEXT_PUBLIC_STRIPE_PRO_PRODUCT_ID="prod_xxx"
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID="price_xxx"
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID="price_xxx"
NEXT_PUBLIC_STRIPE_BUSINESS_PRODUCT_ID="prod_xxx"
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PRICE_ID="price_xxx"
NEXT_PUBLIC_STRIPE_BUSINESS_YEARLY_PRICE_ID="price_xxx"

# -----------------------------------------------------------------------------
# Creem（默认支付方式）
# 获取密钥：https://creem.io/dashboard
# -----------------------------------------------------------------------------
CREEM_API_KEY="creem_sk_your_api_key"
CREEM_WEBHOOK_SECRET="whsec_your_webhook_secret"

# -----------------------------------------------------------------------------
# 数据分析 (PostHog) - 可选
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_key"
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# 数据分析 (Plausible) - 可选
# 自托管或云端 Plausible 分析
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT=https://plausible.io/js/script.js

# -----------------------------------------------------------------------------
# 管理员账户
# 设置邮箱自动授予管理员权限
# -----------------------------------------------------------------------------
ADMIN_EMAIL="your-email@example.com"

# -----------------------------------------------------------------------------
# 调试模式
# -----------------------------------------------------------------------------
IS_DEBUG=false

# -----------------------------------------------------------------------------
# R2/S3 存储
# 从 Cloudflare R2 或 AWS S3 获取凭据
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=your_r2_access_key_id
STORAGE_SECRET_KEY=your_r2_secret_access_key
STORAGE_BUCKET=your_bucket_name
STORAGE_DOMAIN=https://pub-xxx.r2.dev

# -----------------------------------------------------------------------------
# AI 视频提供商
# 从各提供商获取 API 密钥
# -----------------------------------------------------------------------------
# Evolink：https://evolink.ai
EVOLINK_API_KEY=sk-your_evolink_api_key

# Kie.ai：https://kie.ai
KIE_API_KEY=your_kie_api_key

# APImart：https://apimart.ai（支持 Seedance 1.0/1.5、Sora 2、Wan 2.6、Veo 3.1）
APIMART_API_KEY=your_apimart_api_key

# 默认提供商（evolink | kie | apimart）
# 应用仅使用该提供商支持的模型/模式。
# 不支持的模型会从 UI 过滤掉，API 会拒绝请求而非静默降级。
DEFAULT_AI_PROVIDER=evolink

# -----------------------------------------------------------------------------
# AI 回调（生产环境必填）
# 设为你的生产域名
# 本地开发：使用 localhost:3000（回调无法工作，轮询会处理）
# 生产环境：使用实际域名（如 https://videofly.app）
# -----------------------------------------------------------------------------
AI_CALLBACK_URL=https://yourdomain.com/api/v1/video/callback
CALLBACK_HMAC_SECRET=generate_random_secret_here

# -----------------------------------------------------------------------------
# 积分与商品配置（积分与商品配置）
# 所有商品 ID、价格、积分数量统一在 src/config/pricing-user.ts 中管理
# 无需在环境变量中配置
# -----------------------------------------------------------------------------